# OpenClaw API 配置
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18900
OPENCLAW_API_TOKEN=***
WORKSPACE_DIR=D:\bobo\openclaw-foreign\workspace

# collect_failures.py 日志路径（默认 ./logs/gateway.log）
# OPENCLAW_LOG_PATH=D:\bobo\openclaw-foreign\logs\startup-fixed.log

# 门禁：是否要求补丁附带测试证据（1=开启，0=关闭）
REQUIRE_TEST_EVIDENCE=1

# 成本：每日 Token 预算
COST_BUDGET_DAILY=50000
